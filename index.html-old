<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <title>Einkauf 2.0</title>
    

  </head>
    
  <body>
  <!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Familien Einkauf</title>
<style>
body { font-family: Arial; background:#111; color:#eee; margin:0; }
header { padding:15px; background:#1a1a1a; text-align:center; font-size:20px; }
.container { padding:15px; }
.card { background:#1e1e1e; padding:10px; margin:10px 0; border-radius:10px; }
input { width:100%; margin:5px 0; padding:8px; border-radius:6px; border:none; }
button { padding:8px; margin:5px 0; border:none; border-radius:6px; cursor:pointer; }
.primary { background:#4caf50; color:white; }
.danger { background:#c62828; color:white; }
.done { text-decoration: line-through; opacity:0.5; }
.total { font-size:18px; margin-top:10px; }
.small { font-size:12px; opacity:0.7; }
</style>
</head>
<body>
<header>🛒 Einkauf – Familie</header>
<div class="container">

<h3>Budget festlegen</h3>
<input id="budget" type="number" step="0.01" placeholder="Maximal ausgeben €" />
<button onclick="saveBudget()" class="primary">Speichern</button>

<h3>Produkt hinzufügen</h3>
<input id="item" placeholder="Produkt" />
<button onclick="add()" class="primary">Hinzufügen</button>
<button onclick="clearAll()" class="danger">Liste löschen</button>

<h3>Liste</h3>
<div id="list"></div>

<h3>🧮 Einkauf Rechner</h3>
<input id="calc" type="number" step="0.01" placeholder="Preis eingeben" />
<button onclick="addCalc()">+</button>
<button onclick="resetCalc()" class="danger">Reset</button>
<div class="total">Kasse: <span id="real">0.00</span> €</div>
<div class="total">Budget: <span id="budgetShow">0.00</span> €</div>
<div class="total">Rest: <span id="rest">0.00</span> €</div>

<h3>🧠 Letztes Mal gekauft</h3>
<div id="history"></div>
<button onclick="clearHistory()" class="danger">Historie löschen</button>

<h3>🌐 Sync</h3>
<input id="key" placeholder="Geheimer Schlüssel" />
<button onclick="saveCloud()">Speichern</button>
<button onclick="loadCloud()">Laden</button>

</div>

<script>
let items = JSON.parse(localStorage.getItem('items')||'[]');
let history = JSON.parse(localStorage.getItem('history')||'[]');
let real = 0;
let budgetVal = parseFloat(localStorage.getItem('budget')||0);

function saveBudget(){
  budgetVal = parseFloat(budget.value)||0;
  localStorage.setItem('budget', budgetVal);
  renderBudget();
}

function renderBudget(){
  document.getElementById('budgetShow').textContent = budgetVal.toFixed(2);
  updateRest();
}

function add(){
  if(!item.value) return;
  items.push({ name:item.value, done:false });
  save();
  item.value='';
}

function toggle(i){
  items[i].done=!items[i].done;

  if(items[i].done){
    history.unshift({ name: items[i].name, date: new Date().toLocaleDateString() });
    localStorage.setItem('history', JSON.stringify(history));
  }

  save();
  renderHistory();
}

function del(i){
  items.splice(i,1);
  save();
}

function clearAll(){
  if(confirm('Liste löschen?')){
    items=[];
    save();
  }
}

function clearHistory(){
  if(confirm('Historie löschen?')){
    history=[];
    localStorage.setItem('history', JSON.stringify(history));
    renderHistory();
  }
}

function save(){
  localStorage.setItem('items', JSON.stringify(items));
  render();
}

function render(){
  const el = document.getElementById('list'); el.innerHTML='';

  items.forEach((it,i)=>{
    const d = document.createElement('div'); d.className='card';
    d.innerHTML = `
      <div class="${it.done?'done':''}">
      <input type="checkbox" ${it.done?'checked':''} onclick="toggle(${i})">
      ${it.name}
      <button onclick="del(${i})">x</button>
      </div>`;
    el.appendChild(d);
  });
}

function renderHistory(){
  const el = document.getElementById('history'); el.innerHTML='';

  history.slice(0,10).forEach(h=>{
    const d = document.createElement('div'); d.className='card';
    d.innerHTML = `
      ${h.name}
      <div class="small">${h.date}</div>
      <button onclick="reuse('${h.name}')">Wieder kaufen</button>
    `;
    el.appendChild(d);
  });
}

function reuse(name){
  items.push({name, done:false});
  save();
}

function addCalc(){
  real += parseFloat(calc.value)||0;
  document.getElementById('real').textContent = real.toFixed(2);
  calc.value='';
  updateRest();
}

function resetCalc(){
  real = 0;
  document.getElementById('real').textContent='0.00';
  updateRest();
}

function updateRest(){
  const rest = budgetVal - real;
  document.getElementById('rest').textContent = rest.toFixed(2);
}

// einfache Cloud
async function saveCloud(){
  if(!key.value) return alert('Key fehlt');
  await fetch(`https://jsonblob.com/api/jsonBlob/${key.value}`,{
    method:'PUT',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({items, history, budgetVal})
  });
  alert('Gespeichert');
}

async function loadCloud(){
  if(!key.value) return alert('Key fehlt');
  const res = await fetch(`https://jsonblob.com/api/jsonBlob/${key.value}`);
  const data = await res.json();
  items = data.items||[];
  history = data.history||[];
  budgetVal = data.budgetVal||0;
  localStorage.setItem('items', JSON.stringify(items));
  localStorage.setItem('history', JSON.stringify(history));
  localStorage.setItem('budget', budgetVal);
  render();
  renderHistory();
  renderBudget();
}

render();
renderHistory();
renderBudget();
</script>
</body>
</html>
    
  </body>
  
</html>
